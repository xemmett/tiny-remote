{
  "name": "tiny-remote-desktop",
  "version": "0.1.0",
  "description": "Desktop shell for Tiny Remote - runs backend and frontend, shows status and QR",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.tinyremote.app",
    "productName": "Tiny Remote",
    "directories": { "output": "dist-electron" },
    "files": ["main.js", "index.html", "preload.js"],
    "win": { "target": "portable" },
    "extraResources": [
      { "from": "../pc-control/dist/backend.exe", "to": "backend.exe" },
      { "from": "../frontend/build/frontend.exe", "to": "frontend.exe" },
      { "from": "../frontend/dist", "to": "dist" }
    ]
  }
}
